DATABASE_URL='postgresql+asyncpg://neondb_owner:.......@ep-......aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# Point to the Prisma-managed app database (same Postgres, different db name).
# Uses the async driver. Falls back to DATABASE_URL if unset.
# Example: postgresql+asyncpg://admin:admin123@localhost:5432/app
APP_DATABASE_URL=

# uv run fastapi dev

# source .venv/bin/activate
# python3 app/livekit_agent.py dev
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

FRONTEND_ORIGINS=http://localhost:3000
PORT=8000

# Set to "true" to use hardcoded mock tools instead of querying the database.
# Default (unset or empty) = false, reads tools from the Workflow table.
USE_MOCK_TOOLS=
TOOLS_API_URL=http://localhost:8000/agent/tools


# Create a trunk: LiveKit Console → SIP → Outbound Trunks → Copy the ID
LIVEKIT_SIP_TRUNK_ID=
AGENT_NAME=assistant


ROOM_EMPTY_TIMEOUT_SEC=300   # auto-close room after N seconds with no participants
ROOM_MAX_PARTICIPANTS=10
TOKEN_TTL_SEC=3600           # participant JWT lifetime (1 hour)
